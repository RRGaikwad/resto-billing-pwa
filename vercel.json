{
  "version": 2,
  "builds": [
    {
      "src": "restaurant-invoice-pwa.html",
      "use": "@vercel/static"
    },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/restaurant-invoice-pwa.html"
    }
  ]
}
